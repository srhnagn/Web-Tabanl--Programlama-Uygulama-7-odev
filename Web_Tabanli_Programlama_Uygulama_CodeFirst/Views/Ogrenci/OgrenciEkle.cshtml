@model Web_Tabanli_Programlama_Uygulama_CodeFirst.Models.Ogrenci


<div class="bg-success text-white m-5"> </div>
<form asp-action="OgrenciEkle" method="post" class="m-5"> 
    <div class="form-group"> <label>Ogrenci Adi</label> 
    <input class="form-control" asp-for="Ad"> 
    </div> 
    
    <div class="form-group"> <label>Ogrenci Soyadi</label> 
    <input class="form-control" asp-for="Soyad"> 
    </div> 
    
    <div class="form-group"> 
        <label>Ogrenci Sinif</label> 
        <input class="form-control" asp-for="Sinif"> 
    </div> 

    <div class="form-group"> 
        <label>Ogrenci Eposta</label> 
        <input class="form-control" asp-for="Eposta"> 
    </div> 

    <div class="form-group"> 
        <label>Ogrenci Telefon</label> 
        <input class="form-control" asp-for="Telefon"> 
    </div> 

    <div class="form-group"> 
        <label>Ogrenci Sehir</label> 
        <input class="form-control" asp-for="Sehir"> 
    </div> 
    
    <button type="submit" class="btn btn-primary">Submit</button> 
</form>